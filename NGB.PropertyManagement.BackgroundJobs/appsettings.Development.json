{
  "ConnectionStrings": {
    "DefaultConnection": "<value_to_be_substituted_from_env_file>"
  },
  "KeycloakSettings": {
    "Issuer": "<value_to_be_substituted_from_env_file>",
    "ClientIds": [ "ngb-pm-background-jobs" ]
  },
  "BackgroundJobs": {
    "Enabled": true,
    "DefaultTimeZoneId": "UTC",
    "NightlyCron": "0 3 * * *",
    "Jobs": {
      "accounting.operations.stuck_monitor": {
        "Cron": "*/5 * * * *",
        "Enabled": true,
        "TimeZoneId": "UTC"
      },
      "accounting.general_journal_entry.auto_reverse.post_due": {
        "Cron": "*/15 * * * *",
        "Enabled": true,
        "TimeZoneId": "UTC"
      },
      "pm.rent_charge.generate_monthly": {
        "Cron": "0 5 * * *",
        "Enabled": true,
        "TimeZoneId": "UTC"
      }
    }
  }
}
